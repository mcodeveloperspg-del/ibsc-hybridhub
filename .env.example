APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.example
APP_MAX_UPLOAD_MB=20

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hybrid_learning_hub
DB_USERNAME=replace_with_database_user
DB_PASSWORD=replace_with_strong_password
DB_CHARSET=utf8mb4

# Optional absolute paths. Leave blank unless your host stores uploads outside the app root.
# UPLOAD_SLIDES_PATH=/home/account/app_uploads/slides
# UPLOAD_RESOURCES_PATH=/home/account/app_uploads/resources
# UPLOAD_STUDENT_PHOTOS_PATH=/home/account/app_uploads/student_photos
